---
/**
 * Revenue bar chart used in case studies. Pure CSS bars (no JS), driven by
 * data so it can be authored from Keystatic via the `barchart` markdoc tag.
 * Each bar: { label, height (0–100), value?, before?, partial?, onlab? }.
 */
interface Bar {
  label: string;
  height: number;
  value?: string;
  before?: boolean;
  partial?: boolean;
  onlab?: string;
}
interface Props {
  title?: string;
  legend?: boolean;
  axisLeft?: string;
  axisRight?: string;
  bars?: Bar[];
}
const { title, legend = false, axisLeft, axisRight, bars = [] } = Astro.props;
---
<div class="chart-wrap">
  {
    (title || legend) && (
      <div class="chart-head">
        {title && <div class="chart-title">{title}</div>}
        {legend && (
          <div class="legend">
            <span><i class="b"></i>Before marketing</span>
            <span><i class="a"></i>After</span>
          </div>
        )}
      </div>
    )
  }
  <div class="bars">
    {
      bars.map((b) => (
        <div class:list={['bar', { before: b.before, partial: b.partial }]}>
          {b.onlab && <div class="onlab">{b.onlab}</div>}
          {b.value && <div class="bv">{b.value}</div>}
          <div class="col" style={`height:${b.height}%`}></div>
          <div class="bl">{b.label}</div>
        </div>
      ))
    }
  </div>
  {
    (axisLeft || axisRight) && (
      <div class="axis-note"><span>{axisLeft}</span><span>{axisRight}</span></div>
    )
  }
</div>

<style>
  .chart-wrap { background: var(--card); border: 1px solid var(--line); border-radius: 16px; padding: 30px 26px 20px; margin: 24px 0; }
  .chart-head { display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 8px; margin-bottom: 26px; }
  .chart-title { font-size: 14px; color: var(--muted); }
  .legend { font-size: 12px; color: var(--muted-2); display: flex; gap: 16px; }
  .legend i { display: inline-block; width: 10px; height: 10px; border-radius: 2px; margin-right: 5px; vertical-align: middle; }
  .legend .a { background: var(--m); }
  .legend .b { background: #3a3d48; }
  .bars { display: flex; align-items: flex-end; gap: clamp(4px, 1.6vw, 24px); height: 232px; padding-top: 24px; }
  .bar { flex: 1; display: flex; flex-direction: column; justify-content: flex-end; align-items: center; height: 100%; position: relative; }
  .bar .col { width: 100%; max-width: 54px; background: var(--grad); border-radius: 4px 4px 0 0; }
  .bar.before .col { background: #3a3d48; }
  .bar.partial .col { opacity: 0.5; }
  .bar .bv { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; font-size: 11px; margin-bottom: 6px; color: #fff; white-space: nowrap; }
  .bar .bl { font-size: 10.5px; color: var(--muted-2); margin-top: 8px; }
  .bar .onlab { position: absolute; top: -6px; font-size: 10px; font-weight: 700; color: var(--m); white-space: nowrap; }
  .axis-note { display: flex; justify-content: space-between; font-size: 12px; color: var(--muted-2); margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--line); }
</style>
