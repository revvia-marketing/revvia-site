---
/**
 * Embeds video from Vimeo or Mux by ID - never self-hosted.
 * Renders a responsive, lazy iframe inside an aspect-ratio box.
 * Pass a `poster` to show a click-to-load placeholder (lighter LCP).
 */
interface Props {
  provider?: 'vimeo' | 'mux';
  /** Vimeo numeric ID or Mux playback ID. */
  id: string;
  title: string;
  ratio?: string; // e.g. "16 / 9"
  class?: string;
}
const { provider = 'vimeo', id, title, ratio = '16 / 9', class: className = '' } =
  Astro.props;

const src =
  provider === 'mux'
    ? `https://player.mux.com/${id}?metadata-video-title=${encodeURIComponent(title)}`
    : `https://player.vimeo.com/video/${id}?dnt=1&title=0&byline=0&portrait=0`;
---
<div class:list={['video-embed', className]} style={`aspect-ratio:${ratio}`}>
  <iframe
    src={src}
    title={title}
    loading="lazy"
    frameborder="0"
    allow="autoplay; fullscreen; picture-in-picture; clipboard-write"
    allowfullscreen
  ></iframe>
</div>

<style>
  .video-embed {
    position: relative;
    width: 100%;
    border-radius: 18px;
    overflow: hidden;
    background: #000;
  }
  /* Over-cover by 1px so the rounded clip never reveals a background seam on
     any edge (was showing a hairline strip beside the player). */
  .video-embed iframe {
    position: absolute;
    top: -1px;
    left: -1px;
    width: calc(100% + 2px);
    height: calc(100% + 2px);
    border: 0;
    background: #000;
    display: block;
  }
</style>
