---
/**
 * In-article image, inserted via the Keystatic "Figure" content component and
 * rendered through the markdoc `figure` tag. align="left"/"right" floats the
 * image so body text wraps around it (magazine style); align="full" runs it
 * full column width. Source images live under src/assets and go through
 * Astro's image pipeline.
 */
import { Image } from 'astro:assets';
import { resolveImage } from '../lib/images';

interface Props {
  src: string;
  align?: 'left' | 'right' | 'full';
  caption?: string;
}
const { src, align = 'left', caption } = Astro.props;
const img = resolveImage(src);

const variant = align === 'right' ? 'right' : align === 'full' ? 'full' : 'left';
const isFull = variant === 'full';
const widths = isFull ? [480, 800, 1200] : [360, 720];
const sizes = isFull
  ? '(max-width: 760px) 100vw, 720px'
  : '(max-width: 639px) 100vw, 320px';
---
{img && (
  <figure class={`fig fig-${variant}`}>
    <Image src={img} alt={caption || ''} widths={widths} sizes={sizes} />
    {caption && <figcaption>{caption}</figcaption>}
  </figure>
)}

<style>
  .fig { margin: 6px 0 18px; }
  .fig :global(img) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 14px;
    border: 1px solid var(--line);
  }
  .fig figcaption { color: var(--muted-2); font-size: 13px; line-height: 1.5; margin-top: 8px; }

  /* Float left/right so body text wraps; stacks full-width on small screens. */
  @media (min-width: 640px) {
    .fig-left,
    .fig-right { max-width: 320px; }
    .fig-left { float: left; margin: 6px 28px 16px 0; }
    .fig-right { float: right; margin: 6px 0 16px 28px; }
  }
</style>
