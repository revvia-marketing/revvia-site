---
import { Image } from 'astro:assets';
import logo from '../assets/revvia-logo.png';
import { NAV_LINKS, CTA } from '../lib/site';

const here = Astro.url.pathname.replace(/\/$/, '') || '/';
/** A nav item is "current" when it matches the path or owns the section. */
function isActive(href: string) {
  if (href === '/') return here === '/';
  return here === href || here.startsWith(href + '/');
}
/** Exact match - used for dropdown children so only one highlights. */
const isExact = (href: string) => here === (href.replace(/\/$/, '') || '/');
---
<nav aria-label="Primary">
  <div class="nav-in">
    <a class="brand" href="/" aria-label="Revvia - home">
      <Image src={logo} alt="Revvia" width={120} height={97} loading="eager" />
      <span class="wm">Revvia</span>
    </a>

    <div class="nav-links" role="list">
      {
        NAV_LINKS.map((l) =>
          l.children ? (
            <div class="navdrop" data-navdrop>
              <a class="navdrop-link" href={l.href} aria-current={isActive(l.href) ? 'page' : undefined}>
                {l.label}
              </a>
              <button
                class="navdrop-toggle"
                type="button"
                aria-haspopup="true"
                aria-expanded="false"
                aria-controls={`nd-${l.label.replace(/\s+/g, '-').toLowerCase()}`}
                aria-label={`${l.label} menu`}
                data-navdrop-toggle
              >
                <svg viewBox="0 0 10 6" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round" /></svg>
              </button>
              <div class="navdrop-menu" id={`nd-${l.label.replace(/\s+/g, '-').toLowerCase()}`} role="menu">
                {l.children.map((c) => (
                  <a role="menuitem" href={c.href} aria-current={isExact(c.href) ? 'page' : undefined}>
                    {c.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a href={l.href} aria-current={isActive(l.href) ? 'page' : undefined}>
              {l.label}
            </a>
          )
        )
      }
      <a href={CTA.href} class="btn" aria-current={isActive(CTA.href) ? 'page' : undefined}>
        {CTA.label}
      </a>
    </div>

    <button
      class="hamburger"
      id="hamburger"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<div class="mobile-menu" id="mobile-menu" hidden>
  <div class="mm-panel" role="dialog" aria-modal="true" aria-label="Site menu">
    <button class="mm-close" id="mm-close" type="button" aria-label="Close menu">
      <span aria-hidden="true">&times;</span>
    </button>
    <nav class="mm-links" aria-label="Mobile">
      {
        NAV_LINKS.map((l) =>
          l.children ? (
            <div class="mm-group">
              <a href={l.href} aria-current={isActive(l.href) ? 'page' : undefined}>{l.label}</a>
              <div class="mm-sub">
                {l.children
                  .filter((c) => c.href !== l.href)
                  .map((c) => (
                    <a href={c.href} aria-current={isExact(c.href) ? 'page' : undefined}>{c.label}</a>
                  ))}
              </div>
            </div>
          ) : (
            <a href={l.href} aria-current={isActive(l.href) ? 'page' : undefined}>{l.label}</a>
          )
        )
      }
      <a href={CTA.href} class="btn btn-lg mm-cta">{CTA.label}</a>
    </nav>
    <div class="mm-tag grad-text">Marketing how it should be.</div>
  </div>
</div>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(10, 10, 12, 0.78);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--line);
  }
  .nav-in {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 14px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-links { display: flex; gap: 28px; align-items: center; }
  .nav-links > a:not(.btn) { font-size: 14.5px; font-weight: 500; color: var(--muted); }
  .nav-links > a:not(.btn):hover,
  .nav-links > a[aria-current='page']:not(.btn) { color: #fff; }

  /* ── Journal dropdown (desktop) ── */
  .navdrop { position: relative; display: inline-flex; align-items: center; gap: 2px; }
  .navdrop-link { font-size: 14.5px; font-weight: 500; color: var(--muted); }
  .navdrop:hover .navdrop-link,
  .navdrop:focus-within .navdrop-link,
  .navdrop-link[aria-current='page'] { color: #fff; }
  .navdrop-toggle {
    background: transparent; border: 0; color: var(--muted); cursor: pointer;
    padding: 6px 2px; display: flex; align-items: center; border-radius: 6px;
  }
  .navdrop:hover .navdrop-toggle, .navdrop:focus-within .navdrop-toggle { color: #fff; }
  .navdrop-toggle svg { width: 11px; height: 11px; transition: transform 0.2s; }
  .navdrop:hover .navdrop-toggle svg,
  .navdrop.open .navdrop-toggle svg { transform: rotate(180deg); }

  .navdrop-menu {
    position: absolute;
    top: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%) translateY(-6px);
    min-width: 224px;
    background: rgba(14, 15, 20, 0.98);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid var(--line-2);
    border-radius: 14px;
    padding: 8px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.16s ease, transform 0.16s ease;
    z-index: 60;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.5);
  }
  /* invisible bridge so the hover doesn't drop crossing the gap */
  .navdrop-menu::before { content: ""; position: absolute; top: -14px; left: 0; right: 0; height: 14px; }
  .navdrop:hover .navdrop-menu,
  .navdrop:focus-within .navdrop-menu,
  .navdrop.open .navdrop-menu {
    opacity: 1; visibility: visible; pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }
  .navdrop-menu a {
    font-size: 14px; color: var(--muted); padding: 9px 12px;
    border-radius: 9px; white-space: nowrap;
  }
  .navdrop-menu a:hover,
  .navdrop-menu a:focus-visible { color: #fff; background: rgba(255, 255, 255, 0.05); }
  .navdrop-menu a[aria-current='page'] { color: #fff; background: rgba(214, 36, 143, 0.12); }

  /* hamburger - hidden on desktop */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 10px;
    background: transparent;
    border: 1px solid var(--line-2);
    border-radius: 10px;
    cursor: pointer;
  }
  .hamburger span {
    display: block;
    height: 2px;
    width: 100%;
    background: #fff;
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }
  body.menu-open .hamburger span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  body.menu-open .hamburger span:nth-child(2) { opacity: 0; }
  body.menu-open .hamburger span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* full-screen mobile overlay */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(10, 10, 12, 0.96);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    opacity: 0;
    transition: opacity 0.22s ease;
  }
  .mobile-menu:not([hidden]) { opacity: 1; }
  .mobile-menu[hidden] { display: none; }

  .mm-panel {
    height: 100%;
    max-width: 520px;
    margin: 0 auto;
    padding: 84px 28px 40px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    overflow-y: auto;
    transform: translateY(-10px);
    transition: transform 0.24s ease;
  }
  .mobile-menu:not([hidden]) .mm-panel { transform: translateY(0); }

  .mm-close {
    position: absolute;
    top: 18px;
    right: 22px;
    width: 44px;
    height: 44px;
    font-size: 30px;
    line-height: 1;
    color: #fff;
    background: transparent;
    border: 1px solid var(--line-2);
    border-radius: 10px;
    cursor: pointer;
  }
  .mm-links { display: flex; flex-direction: column; gap: 6px; }
  .mm-links > a:not(.btn),
  .mm-group > a {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-weight: 700;
    font-size: 30px;
    color: #fff;
    padding: 14px 0;
    border-bottom: 1px solid var(--line);
    letter-spacing: -0.02em;
    display: block;
  }
  .mm-links > a[aria-current='page']:not(.btn),
  .mm-group > a[aria-current='page'] {
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  /* dropdown children inside the mobile menu */
  .mm-sub { display: flex; flex-direction: column; }
  .mm-links .mm-sub a {
    font-family: 'Inter', sans-serif;
    font-size: 17px;
    font-weight: 600;
    color: var(--muted);
    padding: 12px 0 12px 18px;
    border-bottom: 1px solid var(--line);
    letter-spacing: 0;
  }
  .mm-links .mm-sub a:hover { color: #fff; }
  .mm-links .mm-sub a[aria-current='page'] {
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .mm-cta { text-align: center; margin-top: 22px; }
  .mm-tag {
    margin-top: auto;
    padding-top: 22px;
    font-family: 'Bricolage Grotesque', sans-serif;
    font-style: italic;
    font-size: 16px;
  }

  @media (max-width: 860px) {
    .nav-links { display: none; }
    .hamburger { display: flex; }
  }
</style>

<script is:inline>
  /* ── Journal dropdown: click/tap toggle, Escape + click-out close ── */
  (() => {
    const drops = Array.from(document.querySelectorAll('[data-navdrop]'));
    drops.forEach((drop) => {
      const toggle = drop.querySelector('[data-navdrop-toggle]');
      if (!toggle) return;
      const open = () => {
        drop.classList.add('open');
        toggle.setAttribute('aria-expanded', 'true');
      };
      const close = () => {
        drop.classList.remove('open');
        toggle.setAttribute('aria-expanded', 'false');
      };
      toggle.addEventListener('click', (e) => {
        e.preventDefault();
        drop.classList.contains('open') ? close() : open();
      });
      drop.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          close();
          toggle.focus();
        }
      });
      // close when focus leaves the dropdown entirely
      drop.addEventListener('focusout', (e) => {
        if (!drop.contains(e.relatedTarget)) close();
      });
      // close menu after choosing a destination
      drop.querySelectorAll('.navdrop-menu a').forEach((a) =>
        a.addEventListener('click', close)
      );
    });
    document.addEventListener('click', (e) => {
      drops.forEach((drop) => {
        if (!drop.contains(e.target)) {
          drop.classList.remove('open');
          drop.querySelector('[data-navdrop-toggle]')?.setAttribute('aria-expanded', 'false');
        }
      });
    });
  })();

  /* ── Mobile menu ── */
  (() => {
    const btn = document.getElementById('hamburger');
    const menu = document.getElementById('mobile-menu');
    const closeBtn = document.getElementById('mm-close');
    if (!btn || !menu || !closeBtn) return;

    const panel = menu.querySelector('.mm-panel');
    let lastFocused = null;

    const focusable = () =>
      Array.from(
        menu.querySelectorAll(
          'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'
        )
      ).filter((el) => el.offsetParent !== null);

    function openMenu() {
      lastFocused = document.activeElement;
      menu.hidden = false;
      document.body.classList.add('menu-open');
      document.body.style.overflow = 'hidden';
      btn.setAttribute('aria-expanded', 'true');
      btn.setAttribute('aria-label', 'Close menu');
      requestAnimationFrame(() => {
        const f = focusable();
        (f[0] || closeBtn).focus();
      });
      document.addEventListener('keydown', onKeydown);
    }

    function closeMenu() {
      menu.hidden = true;
      document.body.classList.remove('menu-open');
      document.body.style.overflow = '';
      btn.setAttribute('aria-expanded', 'false');
      btn.setAttribute('aria-label', 'Open menu');
      document.removeEventListener('keydown', onKeydown);
      if (lastFocused && typeof lastFocused.focus === 'function') lastFocused.focus();
    }

    function onKeydown(e) {
      if (e.key === 'Escape') {
        e.preventDefault();
        closeMenu();
        return;
      }
      if (e.key === 'Tab') {
        const f = focusable();
        if (f.length === 0) return;
        const first = f[0];
        const last = f[f.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    }

    btn.addEventListener('click', () => (menu.hidden ? openMenu() : closeMenu()));
    closeBtn.addEventListener('click', closeMenu);
    menu.querySelectorAll('a[href]').forEach((a) => a.addEventListener('click', closeMenu));
    menu.addEventListener('click', (e) => {
      if (panel && !panel.contains(e.target)) closeMenu();
    });
  })();
</script>
