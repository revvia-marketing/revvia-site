---
/**
 * Social-proof strip — logos of the brands we work with, right under the hero.
 * Drop logo files into src/assets/brands/ and they appear here automatically
 * (PNG, SVG, JPG, or WebP — transparent PNG/SVG look best). Filename becomes
 * the alt text; an optional leading "NN-" sets order. Until logos are added,
 * it shows client names as text so the strip is never empty.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Raster logos run through Astro's image pipeline (resized + modern formats via
// Netlify's CDN); SVGs are served as-is (vector — nothing to optimize).
const rasterModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/brands/*.{png,jpg,jpeg,webp,avif}',
  { eager: true }
);
const svgModules = import.meta.glob('/src/assets/brands/*.svg', {
  eager: true,
  query: '?url',
  import: 'default',
}) as Record<string, string>;

// Known brand-name casing (filenames can't hold "/" or mixed case).
const NAME_OVERRIDES: Record<string, string> = {
  itan: 'iTAN',
  eversun: 'EverSun',
  'eversun-itan': 'EverSun/iTAN',
};

function prettyName(path: string) {
  const slug = (path.split('/').pop() ?? '')
    .replace(/\.[^.]+$/, '')
    .replace(/^\d+[-_]/, ''); // drop leading "NN-" ordering prefix
  if (NAME_OVERRIDES[slug]) return NAME_OVERRIDES[slug];
  return slug.replace(/[-_]/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
}

const logos = [
  ...Object.entries(rasterModules).map(([path, mod]) => ({ path, img: mod.default, url: undefined as string | undefined })),
  ...Object.entries(svgModules).map(([path, url]) => ({ path, img: undefined as ImageMetadata | undefined, url })),
]
  .sort((a, b) => a.path.localeCompare(b.path, undefined, { numeric: true }))
  .map((l) => ({ ...l, alt: prettyName(l.path) }));

// Real clients — shown as text chips until logo files are dropped in.
const fallbackNames = ['Peter Grimm', 'Voyage Air Guitar', 'EverSun/iTAN', 'For Every Need'];

const hasLogos = logos.length > 0;
---
<section class="brandstrip" aria-label="Brands we work with">
  <div class="wrap bs-in">
    <p class="bs-label">Trusted by consumer &amp; lifestyle brands across Southern California</p>
    {
      hasLogos ? (
        <ul class="bs-logos">
          {logos.map((l) => (
            <li>
              {l.img ? (
                <Image src={l.img} alt={l.alt} height={76} densities={[1, 2]} loading="lazy" decoding="async" />
              ) : (
                <img src={l.url} alt={l.alt} loading="lazy" decoding="async" />
              )}
            </li>
          ))}
        </ul>
      ) : (
        <ul class="bs-names" aria-label="A few of the brands we work with">
          {fallbackNames.map((n) => <li>{n}</li>)}
        </ul>
      )
    }
  </div>
</section>

<style>
  .brandstrip { border-bottom: 1px solid var(--line); background: var(--bg); padding: 26px 0; }
  .bs-in { display: flex; flex-direction: column; align-items: center; gap: 18px; }
  .bs-label {
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted-2);
    font-weight: 600;
    text-align: center;
  }

  .bs-logos {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 28px 48px;
    width: 100%;
  }
  .bs-logos li { display: flex; }
  .bs-logos img {
    height: 38px;
    width: auto;
    max-width: 160px;
    object-fit: contain;
    /* monochrome on the dark theme; full color on hover */
    filter: grayscale(1) brightness(0) invert(1) opacity(0.62);
    transition: filter 0.18s, transform 0.18s;
  }
  .bs-logos li:hover img { filter: none; transform: translateY(-2px); }

  /* placeholder client names until real logos drop in */
  .bs-names {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 12px 14px;
  }
  .bs-names li {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-weight: 700;
    font-size: clamp(15px, 2vw, 19px);
    color: var(--muted);
    padding: 8px 16px;
    border: 1px solid var(--line);
    border-radius: 999px;
  }

  @media (prefers-reduced-motion: reduce) {
    .bs-logos li:hover img { transform: none; }
  }
</style>
