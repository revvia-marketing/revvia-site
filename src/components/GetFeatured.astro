---
/**
 * "Get featured" page for a feature publication. Walks a prospect through how
 * the interview works (steps from SERIES_META.getFeatured) and presents a
 * feature-intent form (FeatureForm) - separate from the sales contact flow.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import FeatureForm from './FeatureForm.astro';
import { SERIES_META, type SeriesKey } from '../content.config';
import { breadcrumbSchema } from '../lib/schema';

interface Props { series: SeriesKey; }
const { series } = Astro.props;
const meta = SERIES_META[series];
const gf = meta.getFeatured;
if (!gf) throw new Error(`getFeatured content missing for series "${series}"`);

const pubUrl = `/journal/${meta.slug}`;
const url = `${pubUrl}/get-featured`;

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Journal', url: '/journal' },
  { name: meta.label, url: pubUrl },
  { name: 'Get featured', url },
];

const schemas = [breadcrumbSchema(crumbs)];
---
<BaseLayout
  title={`Get featured in ${meta.label}`}
  description={gf.lead}
  path={url}
  schemas={schemas}
>
  <header class="page-hero">
    <div class="page-hero-in masthead">
      <Breadcrumbs crumbs={crumbs} class="hero-crumbs" />
      <div class="bar" style={`background:${meta.barBg}`}></div>
      <div class="eyebrow">{meta.label}</div>
      <h1>Get featured in {meta.label}.</h1>
      <p class="lead hero-sub">{gf.lead}</p>
    </div>
  </header>

  <section class="psec">
    <div class="wrap gf-grid">
      <div class="gf-steps">
        <div class="eyebrow blk">How it works</div>
        <ol class="steps">
          {gf.process.map((s, i) => (
            <li class="step">
              <span class="step-n" style={`color:${meta.accent}`}>{String(i + 1).padStart(2, '0')}</span>
              <div>
                <h3>{s.title}</h3>
                <p>{s.text}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>

      <div class="gf-form" id="apply">
        <div class="eyebrow blk">Get started</div>
        <h2 class="sec">Tell us about your {gf.noun}.</h2>
        <FeatureForm
          formName={`feature-${meta.slug}`}
          label={meta.label}
          noun={gf.noun}
          locationLabel={gf.locationLabel}
          locationPlaceholder={gf.locationPlaceholder}
          successPath={url}
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-crumbs { margin-bottom: 16px; }
  .masthead .bar { width: 42px; height: 5px; border-radius: 3px; margin-bottom: 18px; }
  .masthead h1 {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-weight: 800;
    font-size: clamp(32px, 5vw, 54px);
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-top: 10px;
    max-width: 820px;
  }
  .hero-sub { max-width: 640px; margin-top: 16px; }

  .gf-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
  @media (max-width: 900px) { .gf-grid { grid-template-columns: 1fr; gap: 36px; } }

  .steps { list-style: none; margin: 18px 0 0; padding: 0; display: flex; flex-direction: column; gap: 26px; }
  .step { display: flex; gap: 16px; }
  .step-n { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800; font-size: 18px; line-height: 1.45; min-width: 28px; }
  .step h3 { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; font-size: 18px; color: #fff; margin-bottom: 5px; }
  .step p { color: var(--muted); font-size: 15px; line-height: 1.6; }

  .gf-form .sec { margin-bottom: 18px; }
</style>
