---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import PostCard from './PostCard.astro';
import CTASection from './CTASection.astro';
import { SERIES_META, type SeriesKey } from '../content.config';
import { breadcrumbSchema, itemListSchema } from '../lib/schema';

interface Props { series: SeriesKey; }
const { series } = Astro.props;
const meta = SERIES_META[series];
const url = `/journal/${meta.slug}`;

const posts = (await getCollection('journal'))
  .filter((p) => p.data.series === series)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Journal', url: '/journal' },
  { name: meta.label, url },
];

const schemas = [
  breadcrumbSchema(crumbs),
  itemListSchema({
    name: meta.label,
    items: posts.map((p) => ({ name: p.data.title, url: `/journal/${p.id}` })),
  }),
];
---
<BaseLayout title={meta.label} description={meta.desc} path={url} schemas={schemas}>
  <header class="page-hero">
    <div class="page-hero-in" style="padding-bottom:40px">
      <Breadcrumbs crumbs={crumbs} class="hero-crumbs" />
      <div class="bar" style={`background:${meta.barBg}`}></div>
      <div class="eyebrow">The Journal</div>
      <h1>{meta.label}</h1>
      <p class="sub">{meta.desc}</p>
    </div>
  </header>

  <section class="psec">
    <div class="wrap">
      {posts.length > 0 ? (
        <div class="posts">{posts.map((post) => <PostCard post={post} />)}</div>
      ) : (
        <p class="empty">New posts in this series are on the way — check back soon.</p>
      )}
      {series === 'built-in-san-diego' && (
        <div class="invite">
          <div>
            <div class="t">Run a North County business?</div>
            <div class="d">We feature local builders for free — a published article, a backlink, and your story told right.</div>
          </div>
          <a class="btn btn-ghost" href="/contact">Get featured →</a>
        </div>
      )}
    </div>
  </section>

  <CTASection
    heading="Want your brand's growth written about next?"
    lead="It starts the same way every story here does — with a growth audit. We'll show you where the revenue is hiding."
  />
</BaseLayout>

<style>
  .hero-crumbs { margin-bottom: 16px; }
  .page-hero .bar { width: 42px; height: 5px; border-radius: 3px; margin-bottom: 18px; }
  .posts { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  @media (max-width: 820px) { .posts { grid-template-columns: 1fr; } }
  .empty { color: var(--muted); font-size: 16px; }
  .invite { border: 1px solid var(--line); border-radius: 16px; background: var(--bg-2); padding: 22px 26px; display: flex; align-items: center; justify-content: space-between; gap: 18px; flex-wrap: wrap; margin-top: 24px; }
  .invite .t { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; font-size: 17px; color: #fff; }
  .invite .d { color: var(--muted); font-size: 14px; margin-top: 2px; }
</style>
