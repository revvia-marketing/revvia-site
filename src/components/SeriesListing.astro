---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import PostCard from './PostCard.astro';
import CTASection from './CTASection.astro';
import Faq from './Faq.astro';
import { SERIES_META, type SeriesKey } from '../content.config';
import {
  breadcrumbSchema,
  collectionPageSchema,
  faqPageSchema,
} from '../lib/schema';

interface Props { series: SeriesKey; }
const { series } = Astro.props;
const meta = SERIES_META[series];
const url = `/journal/${meta.slug}`;
const isFeature = meta.type === 'feature';

const posts = (await getCollection('journal'))
  .filter((p) => p.data.series === series)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Journal', url: '/journal' },
  { name: meta.label, url },
];

const schemas = [
  breadcrumbSchema(crumbs),
  collectionPageSchema({
    name: `${meta.label} - Revvia Journal`,
    description: meta.oneLiner,
    url,
    blog: true,
    posts: posts.map((p) => ({
      name: p.data.title,
      url: `/journal/${p.id}`,
      datePublished: p.data.date.toISOString().slice(0, 10),
    })),
  }),
  ...(isFeature && meta.faqs ? [faqPageSchema([...meta.faqs])] : []),
];
---
<BaseLayout
  title={meta.label}
  description={meta.oneLiner}
  path={url}
  schemas={schemas}
>
  <header class="page-hero">
    <div class="page-hero-in masthead">
      <Breadcrumbs crumbs={crumbs} class="hero-crumbs" />
      <div class="bar" style={`background:${meta.barBg}`}></div>
      <div class="eyebrow">{meta.label}</div>
      <h1>{meta.oneLiner}</h1>
    </div>
  </header>

  <section class="psec">
    <div class="wrap">
      <div class="eyebrow blk">What is {meta.label}?</div>
      <p class="lead intro">{meta.intro}</p>
    </div>
  </section>

  <section class="psec">
    <div class="wrap">
      <div class="eyebrow blk">Latest</div>
      <h2 class="sec">{isFeature ? 'Recent features.' : 'Recent notes.'}</h2>
      {posts.length > 0 ? (
        <div class="posts">{posts.map((post) => <PostCard post={post} />)}</div>
      ) : (
        <p class="empty">
          {isFeature
            ? 'The first features are publishing soon - want to be one of them?'
            : 'New notes are on the way - check back soon.'}
        </p>
      )}
      {isFeature && meta.invite && (
        <div class="invite">
          <div>
            <div class="t">{meta.invite.title}</div>
            <div class="d">{meta.invite.text}</div>
          </div>
          <a class="btn btn-ghost" href="/contact">Get featured →</a>
        </div>
      )}
    </div>
  </section>

  {isFeature && meta.faqs && (
    <section class="psec">
      <div class="wrap">
        <div class="eyebrow blk">FAQ</div>
        <h2 class="sec">Questions about being featured.</h2>
        <Faq items={[...meta.faqs]} />
      </div>
    </section>
  )}

  <CTASection
    heading={meta.cta.heading}
    lead={meta.cta.lead}
    buttonLabel={meta.cta.buttonLabel}
    buttonHref="/contact"
  />
</BaseLayout>

<style>
  .hero-crumbs { margin-bottom: 16px; }
  .masthead .bar { width: 42px; height: 5px; border-radius: 3px; margin-bottom: 18px; }
  .masthead h1 {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-weight: 800;
    font-size: clamp(34px, 5.4vw, 60px);
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-top: 10px;
    max-width: 900px;
  }
  .intro { max-width: 760px; }
  .posts { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  @media (max-width: 820px) { .posts { grid-template-columns: 1fr; } }
  .empty { color: var(--muted); font-size: 16px; }
  .invite { border: 1px solid var(--line); border-radius: 16px; background: var(--bg-2); padding: 22px 26px; display: flex; align-items: center; justify-content: space-between; gap: 18px; flex-wrap: wrap; margin-top: 28px; }
  .invite .t { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; font-size: 17px; color: #fff; }
  .invite .d { color: var(--muted); font-size: 14px; margin-top: 2px; max-width: 560px; }
</style>
