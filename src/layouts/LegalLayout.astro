---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  path: string;
  updated?: string;
}
const { title, description, path, updated = 'June 2026' } = Astro.props;
---
<BaseLayout title={title} description={description} path={path}>
  <header class="page-hero">
    <div class="page-hero-in" style="padding-bottom:36px">
      <div class="eyebrow">Legal</div>
      <h1>{title}</h1>
      <p class="sub">Last updated {updated}.</p>
    </div>
  </header>

  <section class="psec">
    <div class="wrap">
      <div class="legal-note" role="note">
        <strong>Placeholder — needs legal review.</strong> This document is starter
        copy and is <em>not</em> legal advice. Have counsel review and finalize it
        before launch.
      </div>
      <div class="prose legal-prose">
        <slot />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .legal-note {
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-left: 3px solid var(--gold);
    border-radius: 12px;
    padding: 16px 20px;
    color: var(--muted);
    font-size: 14.5px;
    margin-bottom: 32px;
    max-width: 760px;
  }
  .legal-note strong { color: #fff; }
  .legal-prose :global(h2) { margin-top: 36px; }
  .legal-prose :global(p), .legal-prose :global(li) { font-size: 16.5px; color: var(--muted); }
</style>
