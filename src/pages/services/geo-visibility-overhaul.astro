---
/**
 * GEO Visibility Overhaul - service landing page.
 * Single prerendered route so Netlify detects the two forms. Adapted from the
 * standalone concept into Revvia's BaseLayout + dark design system; the
 * "receipt" motif is kept as the page signature, recolored for the dark UI.
 *
 * Two Netlify forms (separate intent streams):
 *   geo-scorecard-request  - high intent, fires from the readiness widget.
 *   geo-landing-contact    - catch-all at the bottom.
 * Readiness widget posts to the Netlify function at /api/geo-readiness.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { serviceSchema, faqPageSchema, breadcrumbSchema, type FaqItem } from '../../lib/schema';

const path = '/services/geo-visibility-overhaul';
const description =
  'We rebuild your site so AI engines - ChatGPT, Perplexity, Gemini, and Claude - can find, trust, and cite you, with a before-and-after citation scorecard.';

const faqs: FaqItem[] = [
  { question: 'Is this just SEO with a new name on the invoice?', answer: "No. SEO gets you ranked in Google's links. GEO gets you cited in AI answers - ChatGPT, Perplexity, Gemini, and Claude. Different engines, different signals, different proof. We measure citations, not just rankings." },
  { question: 'How do you prove it actually worked?', answer: 'A citation scorecard: the exact queries you win and lose, by engine, re-checked at 30, 60, and 90 days. You see the before-and-after, not a vague "AI-optimized" badge.' },
  { question: 'What does the overhaul change on my site?', answer: 'Structured data matched to real content, a Person and E-E-A-T foundation for your founder, consistent entity signals across the web, and crawler hygiene (llms.txt, robots, render checks) so AI bots can actually read you.' },
  { question: 'Is the readiness check the same as the scorecard?', answer: "No. The readiness check is an instant, automated read on the signals your site controls - schema, llms.txt, bylines, crawler access. It tells you whether engines can read you. The scorecard tells you whether they actually cite you, which we build together." },
];

const schemas = [
  serviceSchema({
    name: 'GEO Visibility Overhaul',
    description,
    url: path,
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Services', url: '/services' },
    { name: 'GEO Visibility Overhaul', url: path },
  ]),
  faqPageSchema(faqs),
];
---
<BaseLayout
  title="GEO Visibility Overhaul"
  description={description}
  path={path}
  schemas={schemas}
>
  <!-- 1 · HERO -->
  <header class="page-hero">
    <div class="page-hero-in">
      <div class="eyebrow">AI visibility</div>
      <h1>When someone asks ChatGPT to recommend a brand like yours, <span class="grad-text">do you show up?</span></h1>
      <p class="sub">We rebuild your site so AI engines can find, trust, and cite you - and we show you the before-and-after.</p>
      <div class="geo-cta-row">
        <a class="btn btn-lg" href="#readiness">Get your AI visibility scorecard</a>
        <a class="btn btn-ghost btn-lg" href="#how">See how it works</a>
      </div>
    </div>
  </header>

  <!-- 2 · THE SHIFT -->
  <section class="psec">
    <div class="wrap">
      <div class="eyebrow blk">The shift</div>
      <h2 class="sec">Search moved. Your site didn't.</h2>
      <p class="lead mut">A quarter of search is shifting to AI answers. Most sites are invisible to the engines doing the answering - not because the work is bad, but because it was never built to be read by a machine that cites sources.</p>
      <ul class="geo-chips">
        <li>~25% of search → AI answers</li>
        <li>Cited 3× more with clean structured data</li>
        <li>Only 16% of brands track AI visibility</li>
      </ul>
    </div>
  </section>

  <!-- 3 · EXHIBIT A -->
  <section class="psec bg2">
    <div class="wrap">
      <div class="geo-kicker">We post receipts - starting with our own.</div>
      <div class="geo-receipt">
        <div class="head"><span>AI visibility check</span><span>Revvia</span></div>
        <p class="geo-prompt">prompt: "best growth agency for consumer brands in San Diego"</p>
        <div class="geo-rows">
          <div class="geo-rrow"><span>ChatGPT</span><i class="geo-leader"></i><span class="geo-ok">named</span></div>
          <div class="geo-rrow"><span>Perplexity</span><i class="geo-leader"></i><span class="geo-ok">named</span></div>
          <div class="geo-rrow"><span>Gemini</span><i class="geo-leader"></i><span class="geo-ok">named</span></div>
          <div class="geo-rrow"><span>Claude</span><i class="geo-leader"></i><span class="geo-ok">named</span></div>
        </div>
        <p class="geo-foot">No competitor's GEO page can show this, because most of them aren't cited either.</p>
      </div>
    </div>
  </section>

  <!-- 4 · CLIENT PROOF -->
  <section class="psec">
    <div class="wrap">
      <div class="eyebrow blk">Client proof</div>
      <h2 class="sec">Top spots for its highest-value terms - in one of San Diego's most competitive home-services markets.</h2>
      <p class="lead mut">Drain and plumbing search in San Diego is as crowded as it gets. After the GEO rebuild - structured data, an E-E-A-T foundation for the founder, and a citation scorecard - Drain Mob now holds top placement on its core service terms against entrenched competition.</p>
      <ul class="geo-chips">
        <li>Top spot · core service term</li>
        <li>Top spot · core service term</li>
        <li>Highly competitive SD market</li>
      </ul>
    </div>
  </section>

  <!-- 5 · THE OVERHAUL -->
  <section class="psec bg2">
    <div class="wrap">
      <div class="eyebrow blk">The work</div>
      <h2 class="sec">The overhaul, in five layers.</h2>
      <dl class="geo-layers">
        <div><dt>Structured data</dt><dd>JSON-LD for the pages that earn it - matched to visible content, never bolted on.</dd></div>
        <div><dt>Founder + E-E-A-T</dt><dd>Person schema, real bylines, and the credibility signals AI weighs before it cites you.</dd></div>
        <div><dt>Entity consistency</dt><dd>One clear story across your site, About page, and third-party profiles.</dd></div>
        <div><dt>Crawler hygiene</dt><dd>llms.txt, robots, and render checks so AI bots can actually read the page.</dd></div>
        <div><dt>Citation baseline + re-check</dt><dd>A before-and-after across the engines at 30, 60, and 90 days.</dd></div>
      </dl>
    </div>
  </section>

  <!-- 6 · REAL VS RELABELED -->
  <section class="psec">
    <div class="wrap">
      <div class="eyebrow blk">The difference</div>
      <h2 class="sec">Real GEO, not SEO with a new word on the invoice.</h2>
      <div class="geo-versus">
        <div class="geo-vcard">
          <div class="vlabel">What most shops sell</div>
          <p>"AI optimization" that's the old SEO playbook with new vocabulary - and no proof it worked.</p>
        </div>
        <div class="geo-vcard accent">
          <div class="vlabel">What we sell</div>
          <p>A citation log. We show you the exact queries you won and lost, by engine, over time.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 7 · HOW IT WORKS -->
  <section id="how" class="psec bg2">
    <div class="wrap">
      <div class="eyebrow blk">How it works</div>
      <h2 class="sec">Three steps.</h2>
      <ol class="geo-steps">
        <li><span class="n">1</span><div><strong>Scorecard</strong><p>See exactly where you stand across the engines.</p></div></li>
        <li><span class="n">2</span><div><strong>Overhaul</strong><p>We fix the gaps and set your citation baseline.</p></div></li>
        <li><span class="n">3</span><div><strong>Monitoring</strong><p>We hold the ground and re-baseline as the engines shift.</p></div></li>
      </ol>
    </div>
  </section>

  <!-- 8 · READINESS CHECK -->
  <section id="readiness" class="psec">
    <div class="wrap">
      <div class="eyebrow blk">Readiness check</div>
      <h2 class="sec">Check your AI readiness.</h2>
      <p class="lead mut">A fast, automated read on the signals your site controls - schema, llms.txt, bylines, crawler access. This is readiness, not citation: it tells you whether the engines <em>can</em> read you. Whether they <em>do</em> cite you is the full scorecard, which we build together.</p>
      <div class="geo-checker">
        <div class="geo-checker-row">
          <input id="domain" type="text" inputmode="url" placeholder="yourdomain.com" autocomplete="off" aria-label="Your domain" />
          <button id="run" class="btn" type="button">Run check</button>
        </div>
        <div id="result" class="geo-result" hidden></div>
      </div>
    </div>
  </section>

  <!-- 8b · DEDICATED SCORECARD REQUEST FORM (revealed by the widget) -->
  <section id="scorecard-request" class="psec bg2" hidden>
    <div class="wrap">
      <div class="eyebrow blk">Full scorecard</div>
      <h2 class="sec">Request your full citation scorecard.</h2>
      <p class="lead mut">The readiness check shows what's missing. The full scorecard shows whether ChatGPT, Perplexity, Gemini, and Claude actually name you for the queries your buyers ask - and what to do about it. Tell us where to look.</p>

      <form id="scorecard-form" class="form-card" name="geo-scorecard-request" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/services/geo-visibility-overhaul?submitted=true">
        <input type="hidden" name="form-name" value="geo-scorecard-request" />
        <input type="hidden" name="request-type" value="full-citation-scorecard" />
        <input type="hidden" name="lead-source" value="geo-readiness-widget" />
        <input type="hidden" name="readiness-score" id="sc-score" value="" />
        <p class="hp" aria-hidden="true"><label>Leave blank <input name="bot-field" tabindex="-1" autocomplete="off" /></label></p>
        <div class="form-row">
          <div class="field"><label for="sc-name">Name</label><input id="sc-name" name="name" type="text" autocomplete="name" required /></div>
          <div class="field"><label for="sc-email">Email</label><input id="sc-email" name="email" type="email" autocomplete="email" required /></div>
        </div>
        <div class="form-row">
          <div class="field"><label for="sc-company">Company</label><input id="sc-company" name="company" type="text" autocomplete="organization" /></div>
          <div class="field"><label for="sc-domain">Domain</label><input id="sc-domain" name="domain" type="text" placeholder="yourdomain.com" required /></div>
        </div>
        <div class="field full"><label for="sc-q">The one query you most want to show up for</label><input id="sc-q" name="biggest-question" type="text" placeholder='e.g. "drain cleaning near me"' /></div>
        <button class="btn btn-lg" type="submit">Send scorecard request</button>
        <div class="form-note geo-done" hidden>Got it - we'll come back with your scorecard scope. You'll know exactly what we found before we talk.</div>
      </form>
    </div>
  </section>

  <!-- 9 · FAQ -->
  <section class="psec">
    <div class="wrap">
      <div class="eyebrow blk">FAQ</div>
      <h2 class="sec">Questions about GEO.</h2>
      <div class="faq">
        {faqs.map((f) => (
          <details>
            <summary>{f.question}</summary>
            <p>{f.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- 10 · CLOSE + CONTACT -->
  <section id="contact" class="psec bg2">
    <div class="wrap">
      <div class="eyebrow blk">Get started</div>
      <h2 class="sec">Want to see where you stand?</h2>
      <p class="lead mut">Run the readiness check above, or just say hello and we'll take it from there.</p>

      <form id="contact-form" class="form-card" name="geo-landing-contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/services/geo-visibility-overhaul?submitted=true">
        <input type="hidden" name="form-name" value="geo-landing-contact" />
        <input type="hidden" name="lead-source" value="geo-landing-page" />
        <p class="hp" aria-hidden="true"><label>Leave blank <input name="bot-field" tabindex="-1" autocomplete="off" /></label></p>
        <div class="form-row">
          <div class="field"><label for="c-name">Name</label><input id="c-name" name="name" type="text" autocomplete="name" required /></div>
          <div class="field"><label for="c-email">Email</label><input id="c-email" name="email" type="email" autocomplete="email" required /></div>
        </div>
        <div class="field full"><label for="c-company">Company</label><input id="c-company" name="company" type="text" autocomplete="organization" /></div>
        <div class="field full"><label for="c-msg">Anything you want us to know?</label><textarea id="c-msg" name="message" rows="3"></textarea></div>
        <button class="btn btn-lg" type="submit">Get in touch</button>
        <div class="form-note geo-done" hidden>Thanks - we'll be in touch shortly.</div>
      </form>

      <p class="geo-journal">More on this in the journal: <a href="/journal/west-coast-dtc">West Coast DTC</a> · <a href="/journal/built-in-san-diego">Built in San Diego</a></p>
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* GEO page (prefixed .geo-* so JS-injected receipt markup is styled too and
     nothing leaks into the rest of the site). Receipt motif = the signature. */
  .geo-cta-row { display: flex; gap: 12px; flex-wrap: wrap; }

  .geo-chips { display: flex; flex-wrap: wrap; gap: 10px; list-style: none; margin-top: 24px; }
  .geo-chips li {
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
    font-size: 13px; color: var(--muted);
    background: var(--card); border: 1px solid var(--line);
    border-radius: 999px; padding: 7px 14px;
  }

  .geo-kicker {
    font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700;
    font-size: 18px; color: #fff; margin-bottom: 18px;
  }

  /* receipt */
  .geo-receipt {
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
    font-size: 13.5px; background: var(--card); border: 1px solid var(--line);
    border-radius: 8px; max-width: 460px; padding: 20px 22px 22px;
    position: relative; color: var(--muted);
  }
  .geo-receipt::before {
    content: ""; position: absolute; left: 0; right: 0; top: -6px; height: 6px;
    background: radial-gradient(circle at 6px 0, transparent 0 5px, var(--card) 5px) repeat-x;
    background-size: 12px 6px;
  }
  .geo-receipt .head { display: flex; justify-content: space-between; color: #fff; font-weight: 600; border-bottom: 1px dashed var(--line-2); padding-bottom: 10px; letter-spacing: .04em; }
  .geo-prompt { color: var(--muted-2); margin: 12px 0 14px; font-size: 12.5px; }
  .geo-rows { display: flex; flex-direction: column; gap: 9px; }
  .geo-rrow { display: flex; align-items: baseline; }
  .geo-leader { flex: 1; border-bottom: 1px dotted var(--line-2); margin: 0 8px; transform: translateY(-3px); }
  .geo-ok { color: #46c08a; font-weight: 600; }
  .geo-no { color: #ef6d6d; font-weight: 600; }
  .geo-locked span:first-child { color: var(--muted-2); }
  .geo-locked .lock { color: var(--line-2); }
  .geo-foot { margin-top: 16px; color: var(--muted-2); font-size: 12px; border-top: 1px dashed var(--line-2); padding-top: 12px; }
  .geo-foot em { color: #fff; font-style: italic; }

  /* layers */
  .geo-layers { margin-top: 8px; }
  .geo-layers > div { display: grid; grid-template-columns: 220px 1fr; gap: 20px; padding: 18px 0; border-top: 1px solid var(--line); }
  .geo-layers dt { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; color: #fff; }
  .geo-layers dd { margin: 0; color: var(--muted); }

  /* versus */
  .geo-versus { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 8px; }
  .geo-vcard { border: 1px solid var(--line); background: var(--card); border-radius: 16px; padding: 22px 24px; }
  .geo-vcard .vlabel { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: 12px; letter-spacing: .1em; text-transform: uppercase; color: var(--muted-2); margin-bottom: 10px; }
  .geo-vcard p { color: var(--muted); margin: 0; }
  .geo-vcard.accent {
    border: 1px solid transparent;
    background: linear-gradient(var(--card), var(--card)) padding-box, var(--grad) border-box;
  }
  .geo-vcard.accent .vlabel {
    background: var(--grad); -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .geo-vcard.accent p { color: #fff; }

  /* steps */
  .geo-steps { list-style: none; display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 8px; }
  .geo-steps li { display: flex; gap: 14px; align-items: flex-start; border: 1px solid var(--line); background: var(--card); border-radius: 16px; padding: 20px; }
  .geo-steps .n { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800; width: 30px; height: 30px; border-radius: 50%; display: grid; place-items: center; background: var(--grad); color: #fff; flex: none; font-size: 14px; }
  .geo-steps strong { display: block; color: #fff; margin-bottom: 3px; font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; }
  .geo-steps p { color: var(--muted); font-size: 15px; margin: 0; }

  /* checker */
  .geo-checker { margin-top: 24px; max-width: 560px; }
  .geo-checker-row { display: flex; gap: 10px; }
  .geo-checker-row input { flex: 1; min-width: 0; background: var(--bg-2); border: 1px solid var(--line-2); border-radius: 10px; padding: 13px 14px; color: #fff; font-family: inherit; font-size: 15px; }
  .geo-checker-row input:focus { outline: none; border-color: var(--m); }
  .geo-result { margin-top: 20px; }
  .geo-score { display: flex; align-items: baseline; gap: 8px; border-bottom: 1px dashed var(--line-2); padding-bottom: 12px; margin-bottom: 12px; }
  .geo-score b { font-family: 'Bricolage Grotesque', sans-serif; font-size: 34px; font-weight: 800; color: #fff; }
  .geo-score span { color: var(--muted); }
  .geo-breadcrumb { display: inline-block; margin-top: 14px; font-weight: 600; color: #fff; border-bottom: 1px solid var(--m); }
  .geo-breadcrumb:hover { color: var(--m); }
  .geo-note { color: #ef6d6d; }

  .geo-done { color: #46c08a; }
  .geo-journal { margin-top: 26px; color: var(--muted); font-size: 15px; }
  .geo-journal a { color: #fff; border-bottom: 1px solid var(--line-2); }
  .geo-journal a:hover { color: var(--m); }

  @media (max-width: 720px) {
    .geo-layers > div { grid-template-columns: 1fr; gap: 6px; }
    .geo-versus, .geo-steps { grid-template-columns: 1fr; }
  }
</style>

<script>
  const $ = (s, r = document) => r.querySelector(s);

  function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c])
    );
  }

  async function runCheck() {
    const input = $('#domain');
    const btn = $('#run');
    const out = $('#result');
    if (!input || !btn || !out) return;
    const domain = input.value.trim();
    if (!domain) { input.focus(); return; }

    btn.disabled = true; btn.textContent = 'Running…';
    out.hidden = false;
    out.innerHTML = '<p class="geo-prompt">Reading ' + escapeHtml(domain) + '…</p>';

    try {
      const res = await fetch('/api/geo-readiness', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ domain }),
      });
      const data = await res.json();
      if (data.error) { out.innerHTML = '<p class="geo-note">' + escapeHtml(data.error) + '</p>'; return; }
      renderResult(out, data);
    } catch {
      out.innerHTML = '<p class="geo-note">Something went wrong running the check. Try again in a moment.</p>';
    } finally {
      btn.disabled = false; btn.textContent = 'Run check';
    }
  }

  function renderResult(out, data) {
    const previewRows = (data.preview || []).map((p) => {
      const cls = p.status === 'pass' ? 'geo-ok' : 'geo-no';
      const mark = p.status === 'pass' ? 'ready' : 'missing';
      return '<div class="geo-rrow"><span>' + escapeHtml(p.label) + '</span><i class="geo-leader"></i><span class="' + cls + '">' + mark + '</span></div>';
    }).join('');

    const lockedRows = (data.locked || []).map((l) =>
      '<div class="geo-rrow geo-locked"><span>' + escapeHtml(l.label) + '</span><i class="geo-leader"></i><span class="lock">🔒</span></div>'
    ).join('');

    out.innerHTML =
      '<div class="geo-receipt">' +
        '<div class="geo-score"><b>' + escapeHtml(String(data.score)) + '</b><span>/ 100 readiness · ' + escapeHtml(data.grade) + '</span></div>' +
        '<div class="geo-rows">' + previewRows + lockedRows + '</div>' +
        '<p class="geo-foot">Readiness shows whether engines <em>can</em> read you. Whether they <em>cite</em> you is the full scorecard.</p>' +
        '<a class="geo-breadcrumb" id="to-scorecard" href="#scorecard-request">Meet to develop the full citation scorecard →</a>' +
      '</div>';

    const link = $('#to-scorecard');
    if (link) link.addEventListener('click', () => {
      const sec = $('#scorecard-request');
      if (sec) sec.hidden = false;
      const d = $('#sc-domain'); if (d) d.value = data.domain || ($('#domain')?.value.trim() ?? '');
      const sc = $('#sc-score'); if (sc) sc.value = String(data.score);
    });
  }

  async function submitNetlify(form) {
    const data = new FormData(form);
    if (data.get('bot-field')) return; // honeypot tripped
    const name = form.getAttribute('name') || 'geo-landing-contact';
    const body = new URLSearchParams();
    for (const [k, v] of data.entries()) body.append(k, String(v));
    try {
      await fetch('/', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: body.toString() });
    } catch { /* show success anyway so the lead can follow up */ }
    try {
      if (typeof window.gtag === 'function') {
        window.gtag('event', 'generate_lead', { currency: 'USD', value: 1, form_name: name });
      }
      if (typeof window.fbq === 'function') {
        window.fbq('track', 'Lead', { content_name: name === 'geo-scorecard-request' ? 'GEO Scorecard' : 'GEO Contact' });
      }
    } catch { /* analytics never blocks success */ }
    form.querySelectorAll('input, textarea, button').forEach((el) => { el.disabled = true; });
    const done = form.querySelector('.geo-done');
    if (done) done.hidden = false;
  }

  $('#run')?.addEventListener('click', runCheck);
  $('#domain')?.addEventListener('keydown', (e) => { if (e.key === 'Enter') runCheck(); });
  ['#scorecard-form', '#contact-form'].forEach((sel) => {
    const f = $(sel);
    if (f) f.addEventListener('submit', (e) => { e.preventDefault(); submitNetlify(f); });
  });
</script>
