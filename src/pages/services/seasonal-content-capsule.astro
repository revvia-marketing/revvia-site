---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Gallery from '../../components/Gallery.astro';
import CTASection from '../../components/CTASection.astro';
import Faq from '../../components/Faq.astro';
import type { ImageMetadata } from 'astro';
import { buildGalleryTiles } from '../../lib/gallery';
import {
  serviceSchema,
  faqPageSchema,
  breadcrumbSchema,
  type FaqItem,
} from '../../lib/schema';

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Services', url: '/services' },
  { name: 'Seasonal Content Capsule', url: '/services/seasonal-content-capsule' },
];

const included = [
  { t: 'Creative direction & shot list', d: 'A moodboard and shot list mapped to your channels before we shoot a frame.' },
  { t: 'One production day', d: 'Product, lifestyle, and UGC-style — captured in-house in a single session.' },
  { t: '40+ finished photos', d: 'Edited, retouched, and sized for web, social, and ads.' },
  { t: '12+ video clips', d: 'Short-form cuts built for Reels, TikTok, and paid.' },
];

const steps = [
  { n: '1', t: 'Moodboard', d: 'We align on the look, feel, and references before anything is booked.' },
  { n: '2', t: 'Shot list', d: 'Every frame mapped to a channel and a use — nothing wasted.' },
  { n: '3', t: 'Production day', d: 'One focused in-house shoot captures the entire season.' },
  { n: '4', t: 'Edit & deliver', d: 'Retouched, organized, and handed over ready to post.' },
];

const placeholderTiles = [
  { label: 'Lifestyle 01', span: 'big' as const },
  { label: 'Product' },
  { label: 'UGC style', video: true },
  { label: 'Flat lay' },
  { label: 'On model' },
  { label: 'Detail', span: 'wide' as const },
  { label: 'Lifestyle 02' },
  { label: 'Motion', video: true },
  { label: 'Behind the scenes' },
];

const photoModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/galleries/seasonal-content-capsule/*.{jpg,jpeg,png,webp,avif}',
  { eager: true }
);
const built = buildGalleryTiles(photoModules);
const tiles = built.length ? built : placeholderTiles;

const faqs: FaqItem[] = [
  { question: 'How much content do we actually get from one shoot?', answer: 'A typical capsule delivers 40+ finished photos and 12+ short-form video clips — enough to keep your feed, ads, and email fed for a full quarter. We map the exact count to your channels in the shot list before we roll.' },
  { question: 'Do we need to supply products, models, or a location?', answer: 'You send us the products. We handle direction, styling, and the in-house production day, and we’ll arrange models or a location when the shot list calls for them. Everything is planned in the moodboard stage so nothing is a surprise on the day.' },
  { question: 'How is this different from hiring a freelance photographer?', answer: 'A freelancer gives you a handful of images and a slow back-and-forth. The capsule is a single in-house production that captures a whole season of photo and video at once — product, lifestyle, and UGC-style — delivered organized and sized for every channel.' },
  { question: 'How soon can we start posting?', answer: 'We deliver the finished, retouched library in days, not months — organized by channel and use so your team can drop assets straight into social, ads, and email the moment they land.' },
];

const schemas = [
  serviceSchema({
    name: 'Seasonal Content Capsule',
    description:
      'A full season of photo and video shot in one in-house production. A quarter of content in days, not months. By Revvia.',
    url: '/services/seasonal-content-capsule',
    serviceType: 'Content production',
  }),
  faqPageSchema(faqs),
  breadcrumbSchema(crumbs),
];
---
<BaseLayout
  title="Seasonal Content Capsule"
  description="A full season of photo and video shot in one in-house production. A quarter of content in days, not months. By Revvia."
  path="/services/seasonal-content-capsule"
  schemas={schemas}
>
  <header class="page-hero">
    <div class="page-hero-in">
      <Breadcrumbs crumbs={crumbs} class="hero-crumbs" />
      <div class="eyebrow">Production · Photo + Video</div>
      <h1>Seasonal Content <span class="grad-text">Capsule.</span></h1>
      <p class="sub">A full season of photo and video, shot in one production. A quarter of content in days — not months of freelance back-and-forth.</p>
      <div class="hero-cta">
        <a href="/contact" class="btn btn-lg">Get a Growth Audit</a>
        <a href="/services" class="btn btn-lg btn-ghost">All services</a>
      </div>
    </div>
  </header>

  <section class="psec">
    <div class="wrap">
      <div class="eyebrow blk">What it is</div>
      <h2 class="sec">Stop running out of creative.</h2>
      <p class="lead">Running ads and email burns through content fast. The Capsule solves it in one shoot: a single in-house production day that produces a whole season of scroll-stopping photo and video — product, lifestyle, and UGC-style — delivered organized and ready to post.</p>
    </div>
  </section>

  <section class="psec">
    <div class="wrap">
      <div class="eyebrow blk">What's included</div>
      <h2 class="sec">A season’s worth, in one session.</h2>
      <div class="inc">
        {included.map((c) => (
          <div class="c"><div class="ck" aria-hidden="true">✓</div><div><h3>{c.t}</h3><p>{c.d}</p></div></div>
        ))}
      </div>
    </div>
  </section>

  <section class="psec">
    <div class="wrap">
      <div class="eyebrow blk">The work</div>
      <h2 class="sec">The kind of content you’ll get.</h2>
      <p class="lead mut">Product, lifestyle, on-model, flat-lay, and motion — all from one shoot. Your gallery lives here.</p>
      <Gallery tiles={tiles} note="Placeholder gallery — your real capsule shots replace these." />
    </div>
  </section>

  <section class="psec proc">
    <div class="wrap">
      <div class="eyebrow blk">How it works</div>
      <h2 class="sec">From moodboard to delivery.</h2>
      <div class="steps">
        {steps.map((s) => (
          <div class="s"><span class="sn">{s.n}</span><h3>{s.t}</h3><p>{s.d}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="psec">
    <div class="wrap">
      <div class="outcome">
        <div class="eyebrow blk">Why it matters</div>
        <div class="big">A quarter of content, in a couple of days.</div>
        <p>Never scramble for creative again — your feed, ads, and email stay fed for months off a single shoot.</p>
      </div>
    </div>
  </section>

  <section class="psec">
    <div class="wrap">
      <div class="eyebrow blk">FAQ</div>
      <h2 class="sec">Questions about the capsule.</h2>
      <Faq items={faqs} />
    </div>
  </section>

  <CTASection
    heading="Need a season of content without the freelance chaos?"
    lead="Start with a growth audit and we’ll map the capsule your channels actually need."
  />
</BaseLayout>

<style>
  .hero-crumbs { margin-bottom: 16px; }
</style>
