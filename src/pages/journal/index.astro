---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { SERIES_META, type SeriesKey } from '../../content.config';
import { breadcrumbSchema, collectionPageSchema } from '../../lib/schema';

const all = (await getCollection('journal')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const latest = all.slice(0, 6);

const seriesKeys = Object.keys(SERIES_META) as SeriesKey[];
const publications = seriesKeys.map((key) => SERIES_META[key]);

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Journal', url: '/journal' },
  ]),
  collectionPageSchema({
    name: 'The Revvia Journal',
    description:
      "The Revvia Journal - Founder's Notes, Built in San Diego, and West Coast DTC.",
    url: '/journal',
    blog: true,
    posts: latest.map((p) => ({
      name: p.data.title,
      url: `/journal/${p.id}`,
      datePublished: p.data.date.toISOString().slice(0, 10),
    })),
  }),
];
---
<BaseLayout
  title="Journal"
  description="The Revvia Journal - three publications from a San Diego growth studio: Founder's Notes on growth, Built in San Diego local features, and West Coast DTC stories on the consumer brands building the coast."
  path="/journal"
  schemas={schemas}
>
  <header class="page-hero">
    <div class="page-hero-in" style="padding-bottom:50px">
      <div class="eyebrow">The Revvia Journal</div>
      <h1>Three publications. <span class="grad-text">One studio.</span></h1>
      <p class="sub">Founder's Notes is the thinking behind the work. Built in San Diego and West Coast DTC are our free feature series - the local builders and the consumer brands worth knowing.</p>
    </div>
  </header>

  <section class="psec">
    <div class="wrap">
      <div class="pubgrid">
        {publications.map((p) => (
          <a class="pubcard" href={`/journal/${p.slug}`}>
            <div class="pc-bar" style={`background:${p.barBg}`}></div>
            <div class="pc-body">
              <div class="pc-kind" style={`color:${p.accent}`}>{p.type === 'feature' ? 'Feature series' : 'The column'}</div>
              <h2>{p.label}</h2>
              <p>{p.oneLiner}</p>
              <span class="pc-go" style={`color:${p.accent}`}>
                {p.type === 'feature' ? 'Explore the features' : 'Read the notes'} →
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {latest.length > 0 && (
    <section class="psec">
      <div class="wrap">
        <div class="eyebrow blk">Fresh</div>
        <h2 class="sec">Latest across the Journal.</h2>
        <div class="posts">{latest.map((post) => <PostCard post={post} />)}</div>
      </div>
    </section>
  )}

  <section class="sub psec">
    <div class="sub-in">
      <div class="eyebrow">Subscribe</div>
      <h2 style="margin-top:12px">New posts, no spam.</h2>
      <p>Growth notes, local features, and founder stories - straight to your inbox, whenever there's something worth sending.</p>
      <form
        class="subform"
        name="newsletter"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/journal?subscribed=true"
        data-subscribe
      >
        <input type="hidden" name="form-name" value="newsletter" />
        <p class="hp" aria-hidden="true"><label>Leave blank: <input name="bot-field" tabindex="-1" autocomplete="off" /></label></p>
        <label class="sr-only" for="sub-email">Email address</label>
        <input id="sub-email" type="email" name="email" placeholder="you@brand.com" autocomplete="email" required />
        <button type="submit" class="btn">Subscribe</button>
      </form>
      <div class="subnote" data-subscribe-note>We'll never sell your email. Unsubscribe anytime.</div>
    </div>
  </section>
</BaseLayout>

<style>
  /* publication cards */
  .pubgrid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .pubcard {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--line);
    border-radius: 18px;
    overflow: hidden;
    background: var(--card);
    transition: transform 0.18s, border-color 0.18s;
  }
  .pubcard:hover { transform: translateY(-4px); border-color: var(--line-2); }
  .pc-bar { height: 8px; }
  .pc-body { padding: 26px 24px 28px; display: flex; flex-direction: column; flex: 1; }
  .pc-kind { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; font-weight: 700; margin-bottom: 12px; }
  .pubcard h2 { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800; font-size: 24px; letter-spacing: -0.01em; color: #fff; margin-bottom: 8px; }
  .pubcard p { color: var(--muted); font-size: 15px; flex: 1; }
  .pc-go { font-weight: 600; font-size: 14.5px; margin-top: 18px; }
  @media (max-width: 820px) { .pubgrid { grid-template-columns: 1fr; } }

  .posts { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  @media (max-width: 820px) { .posts { grid-template-columns: 1fr; } }

  .sub { border-top: 1px solid var(--line); background: var(--bg-2); }
  .sub-in { max-width: 680px; margin: 0 auto; padding: 60px 28px; text-align: center; }
  .sub-in h2 { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800; font-size: clamp(26px, 3.6vw, 38px); letter-spacing: -0.02em; margin-bottom: 12px; }
  .sub-in p { color: var(--muted); font-size: 16.5px; margin-bottom: 24px; }
  .subform { display: flex; gap: 10px; max-width: 440px; margin: 0 auto; flex-wrap: wrap; align-items: center; }
  .subform input[type="email"] { flex: 1; min-width: 200px; background: var(--bg); border: 1px solid var(--line-2); border-radius: 10px; padding: 14px 16px; color: #fff; font-family: inherit; font-size: 15px; }
  .subform input:focus { outline: none; border-color: var(--m); }
  .subnote { color: var(--muted-2); font-size: 12.5px; margin-top: 14px; }
</style>

<script is:inline>
  (() => {
    const form = document.querySelector('[data-subscribe]');
    const note = document.querySelector('[data-subscribe-note]');
    if (!form) return;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (form.querySelector('[name="bot-field"]')?.value) return;
      const btn = form.querySelector('button[type="submit"]');
      try {
        await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(new FormData(form)).toString(),
        });
      } catch (err) {}
      if (btn) btn.textContent = "You're in.";
      form.querySelector('input[type="email"]').value = '';
      if (note) note.textContent = "Thanks - we'll only send something when it's worth it.";
    });
  })();
</script>
