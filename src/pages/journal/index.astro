---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { SERIES_META, type SeriesKey } from '../../content.config';
import { breadcrumbSchema, itemListSchema } from '../../lib/schema';

const all = (await getCollection('journal')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const featured = all[0];
const featuredMeta = featured ? SERIES_META[featured.data.series] : null;

const seriesKeys = Object.keys(SERIES_META) as SeriesKey[];
const bySeries = seriesKeys.map((key) => ({
  key,
  meta: SERIES_META[key],
  posts: all.filter((p) => p.data.series === key).slice(0, 3),
}));

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Journal', url: '/journal' },
  ]),
  itemListSchema({
    name: 'Revvia Journal',
    items: all.map((p) => ({ name: p.data.title, url: `/journal/${p.id}` })),
  }),
];
---
<BaseLayout
  title="Journal"
  description="The Revvia Journal - Founder's Notes on growth, Built in San Diego local features, and Coastal Drop Founders stories from the brands building on the SoCal coast."
  path="/journal"
  schemas={schemas}
>
  <header class="page-hero">
    <div class="page-hero-in" style="padding-bottom:50px">
      <div class="eyebrow">The Journal</div>
      <h1>Notes, stories, and a few <span class="grad-text">strong opinions.</span></h1>
      <p class="sub">Three threads: what we're learning about growth, the local builders we admire, and the consumer founders building on the coast. Marketing how it should be - written down.</p>
    </div>
  </header>

  {featured && featuredMeta && (
    <div class="wrap feat-wrap">
      <a class="feat" href={`/journal/${featured.id}`}>
        <div class="media" style={`background:${featuredMeta.cardBg}`}></div>
        <div class="body">
          <div class="latest">Latest · {featuredMeta.label}</div>
          <h2>{featured.data.title}</h2>
          <p>{featured.data.excerpt}</p>
          <span style={`font-weight:600;font-size:14.5px;color:${featuredMeta.accent}`}>Read the note →</span>
        </div>
      </a>
    </div>
  )}

  {bySeries.map(({ key, meta, posts }) => (
    <section class="psec">
      <div class="wrap">
        <div class="shead">
          <div>
            <div class="bar" style={`background:${meta.barBg}`}></div>
            <h2>{meta.label}</h2>
            <div class="desc">{meta.desc}</div>
          </div>
          <a href={`/journal/${meta.slug}`} class="all" style={`color:${meta.accent}`}>{meta.allLabel} →</a>
        </div>
        {posts.length > 0 ? (
          <div class="posts">
            {posts.map((post) => <PostCard post={post} />)}
          </div>
        ) : (
          <p class="empty">New posts in this series are on the way.</p>
        )}
        {key === 'built-in-san-diego' && (
          <div class="invite">
            <div>
              <div class="t">Run a North County business?</div>
              <div class="d">We feature local builders for free - a published article, a backlink, and your story told right.</div>
            </div>
            <a class="btn btn-ghost" href="/contact">Get featured →</a>
          </div>
        )}
      </div>
    </section>
  ))}

  <section class="sub psec">
    <div class="sub-in">
      <div class="eyebrow">Subscribe</div>
      <h2 style="margin-top:12px">New posts, no spam.</h2>
      <p>Growth notes, local features, and founder stories - straight to your inbox, whenever there's something worth sending.</p>
      <form
        class="subform"
        name="newsletter"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/journal?subscribed=true"
        data-subscribe
      >
        <input type="hidden" name="form-name" value="newsletter" />
        <p class="hp" aria-hidden="true"><label>Leave blank: <input name="bot-field" tabindex="-1" autocomplete="off" /></label></p>
        <label class="sr-only" for="sub-email">Email address</label>
        <input id="sub-email" type="email" name="email" placeholder="you@brand.com" autocomplete="email" required />
        <button type="submit" class="btn">Subscribe</button>
      </form>
      <div class="subnote" data-subscribe-note>We'll never sell your email. Unsubscribe anytime.</div>
    </div>
  </section>
</BaseLayout>

<style>
  .feat-wrap { padding-top: 44px; padding-bottom: 8px; }
  .feat { display: grid; grid-template-columns: 1.1fr 1fr; border: 1px solid var(--line); border-radius: 20px; overflow: hidden; background: var(--card); transition: transform 0.18s, border-color 0.18s; }
  .feat:hover { transform: translateY(-4px); border-color: var(--m); }
  .feat .media { position: relative; min-height: 300px; overflow: hidden; }
  .feat .media::after { content: ""; position: absolute; inset: 0; background: radial-gradient(360px 240px at 74% 18%, rgba(255, 255, 255, 0.1), transparent 62%); }
  .feat .body { padding: 38px 36px; display: flex; flex-direction: column; justify-content: center; }
  .feat .latest { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted-2); font-weight: 600; margin-bottom: 14px; }
  .feat h2 { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800; font-size: clamp(26px, 3.4vw, 38px); letter-spacing: -0.01em; line-height: 1.1; margin-bottom: 14px; }
  .feat p { color: var(--muted); font-size: 16.5px; margin-bottom: 20px; }
  @media (max-width: 760px) { .feat { grid-template-columns: 1fr; } .feat .media { min-height: 200px; } }

  .shead { display: flex; align-items: flex-end; justify-content: space-between; gap: 18px; flex-wrap: wrap; margin-bottom: 26px; }
  .shead .bar { width: 42px; height: 5px; border-radius: 3px; margin-bottom: 14px; }
  .shead h2 { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; font-size: clamp(24px, 3.2vw, 34px); letter-spacing: -0.01em; }
  .shead .desc { color: var(--muted); font-size: 16px; max-width: 560px; margin-top: 8px; }
  .shead .all { font-size: 14px; font-weight: 600; white-space: nowrap; }

  .posts { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  @media (max-width: 820px) { .posts { grid-template-columns: 1fr; } }
  .empty { color: var(--muted); font-size: 15px; }

  .invite { border: 1px solid var(--line); border-radius: 16px; background: var(--bg-2); padding: 22px 26px; display: flex; align-items: center; justify-content: space-between; gap: 18px; flex-wrap: wrap; margin-top: 20px; }
  .invite .t { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; font-size: 17px; color: #fff; }
  .invite .d { color: var(--muted); font-size: 14px; margin-top: 2px; }

  .sub { border-top: 1px solid var(--line); background: var(--bg-2); }
  .sub-in { max-width: 680px; margin: 0 auto; padding: 60px 28px; text-align: center; }
  .sub-in h2 { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800; font-size: clamp(26px, 3.6vw, 38px); letter-spacing: -0.02em; margin-bottom: 12px; }
  .sub-in p { color: var(--muted); font-size: 16.5px; margin-bottom: 24px; }
  .subform { display: flex; gap: 10px; max-width: 440px; margin: 0 auto; flex-wrap: wrap; align-items: center; }
  .subform input[type="email"] { flex: 1; min-width: 200px; background: var(--bg); border: 1px solid var(--line-2); border-radius: 10px; padding: 14px 16px; color: #fff; font-family: inherit; font-size: 15px; }
  .subform input:focus { outline: none; border-color: var(--m); }
  .subnote { color: var(--muted-2); font-size: 12.5px; margin-top: 14px; }
</style>

<script is:inline>
  (() => {
    const form = document.querySelector('[data-subscribe]');
    const note = document.querySelector('[data-subscribe-note]');
    if (!form) return;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (form.querySelector('[name="bot-field"]')?.value) return;
      const btn = form.querySelector('button[type="submit"]');
      try {
        await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(new FormData(form)).toString(),
        });
      } catch (err) {}
      if (btn) btn.textContent = "You're in.";
      form.querySelector('input[type="email"]').value = '';
      if (note) note.textContent = 'Thanks - we’ll only send something when it’s worth it.';
    });
  })();
</script>
