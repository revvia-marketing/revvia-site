---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTASection from '../../components/CTASection.astro';
import { Image } from 'astro:assets';
import { resolveImage } from '../../lib/images';
import { articleSchema, breadcrumbSchema } from '../../lib/schema';
import { absoluteUrl } from '../../lib/site';

export async function getStaticPaths() {
  const entries = await getCollection('caseStudies');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);

const url = `/work/${entry.id}`;
const cover = resolveImage(d.coverImage);
const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Work', url: '/work' },
  { name: d.client, url },
];
const t = d.transform;

const schemas = [
  articleSchema({
    headline: d.metaTitle || `${d.client}: Revvia Case Study`,
    description: d.metaDescription || d.summary,
    url,
    image: cover ? cover.src : '/og/revvia-og.png',
    datePublished: d.date ? d.date.toISOString().slice(0, 10) : undefined,
    author: 'Revvia',
  }),
  breadcrumbSchema(crumbs),
];
---
<BaseLayout
  title={d.metaTitle || `${d.client} Case Study`}
  description={d.metaDescription || d.summary}
  path={url}
  ogType="article"
  ogImage={cover ? absoluteUrl(cover.src) : undefined}
  publishedTime={d.date ? d.date.toISOString() : undefined}
  schemas={schemas}
>
  <header class="page-hero">
    <div class="page-hero-in cs-hero">
      <Breadcrumbs crumbs={crumbs} class="hero-crumbs" />
      {d.eyebrow && <div class="eyebrow">{d.eyebrow}</div>}
      <h1 class="cs-h1">{d.client}</h1>
      <p class="lede">{d.summary}</p>

      {t && (t.fromValue || t.toValue) && (
        <div class="transform">
          <div class="t-from">
            <div class="t-label">{t.fromLabel}</div>
            <div class="t-val num">{t.fromValue}</div>
          </div>
          <div class="t-arrow">
            <div class="arc" aria-hidden="true">→</div>
            {t.delta && <div class="pct num grad-text">{t.delta}</div>}
          </div>
          <div class="t-to">
            <div class="t-label">{t.toLabel}</div>
            <div class="t-val num grad-text">{t.toValue}</div>
            {t.toSub && <div class="t-sub">{t.toSub}</div>}
          </div>
        </div>
      )}
    </div>
  </header>

  <div class="wrap">
    {
      d.stats.length > 0 && (
        <div class="stats">
          {d.stats.map((s) => (
            <div class="stat"><div class="v grad-text num" set:html={s.value}></div><div class="l">{s.label}</div></div>
          ))}
        </div>
      )
    }

    {cover && (
      <figure class="cs-cover">
        <Image src={cover} alt={`${d.client} — Revvia case study`} widths={[480, 800, 1080]} sizes="(max-width: 1080px) 100vw, 1080px" />
      </figure>
    )}

    <article class="article">
      <Content />
    </article>
  </div>

  <CTASection
    heading={d.ctaHeading || `Find your brand's <span class="grad-text">missing revenue.</span>`}
    lead={d.ctaLead || "Most brands are leaking growth where no one's looking. We'll show you exactly where — start with a growth audit."}
  />
</BaseLayout>

<style>
  .hero-crumbs { margin-bottom: 16px; }
  .cs-hero { padding-bottom: 24px; }
  .cs-h1 { font-size: clamp(46px, 9vw, 96px) !important; margin: 14px 0 12px !important; }
  .lede { font-size: clamp(18px, 2.3vw, 24px); color: var(--muted); max-width: 700px; }

  .transform {
    display: grid; grid-template-columns: 1fr auto 1fr; gap: 22px; align-items: center;
    margin: 44px 0 8px; padding: 32px; background: var(--card); border: 1px solid var(--line); border-radius: 18px;
  }
  .t-label { font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted-2); margin-bottom: 8px; }
  .t-val { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; font-size: clamp(34px, 5.2vw, 58px); }
  .t-from .t-val { color: #6c7480; }
  .t-arrow { display: flex; flex-direction: column; align-items: center; gap: 6px; }
  .t-arrow .arc { font-size: 28px; color: var(--m); }
  .t-arrow .pct { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800; font-size: 26px; }
  .t-to .t-sub { font-size: 14px; margin-top: 4px; color: var(--muted); }
  @media (max-width: 720px) { .transform { grid-template-columns: 1fr; text-align: left; } .t-arrow { flex-direction: row; } }

  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; margin: 30px 0 0; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .stat { padding: 24px 22px; border-right: 1px solid var(--line); }
  .stat:last-child { border-right: none; }
  .stat .v { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800; font-size: clamp(26px, 3.8vw, 40px); line-height: 1; }
  .stat .l { font-size: 13px; color: var(--muted); margin-top: 9px; line-height: 1.35; }
  @media (max-width: 720px) {
    .stats { grid-template-columns: 1fr 1fr; }
    .stat:nth-child(2) { border-right: none; }
    .stat:nth-child(1), .stat:nth-child(2) { border-bottom: 1px solid var(--line); }
  }

  .cs-cover { margin: 34px 0 0; border-radius: 18px; overflow: hidden; border: 1px solid var(--line); }
  .cs-cover :global(img) { width: 100%; height: auto; display: block; }

  /* CMS-authored prose */
  .article { padding: 40px 0 8px; max-width: 820px; }
  .article :global(h2) {
    font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700;
    font-size: clamp(28px, 4vw, 40px); letter-spacing: -0.01em; line-height: 1.1;
    margin: 48px 0 16px; color: #fff;
  }
  .article :global(h2:first-child) { margin-top: 0; }
  .article :global(h3) {
    font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; font-size: 20px;
    margin: 28px 0 8px; color: #fff;
  }
  .article :global(p) { font-size: 18px; color: var(--muted); max-width: 740px; margin-bottom: 16px; }
  .article :global(p strong), .article :global(li strong) { color: #fff; font-weight: 600; }
  .article :global(ul) { list-style: none; margin: 8px 0 20px; display: grid; gap: 14px; max-width: 760px; }
  .article :global(li) {
    background: var(--card); border: 1px solid var(--line); border-radius: 12px;
    padding: 16px 20px; color: var(--muted); font-size: 15.5px; position: relative; padding-left: 44px;
  }
  .article :global(li)::before {
    content: ""; position: absolute; left: 20px; top: 22px;
    width: 9px; height: 9px; border-radius: 50%; background: var(--grad);
  }
  /* the closing takeaway is authored as a markdown blockquote */
  .article :global(blockquote) {
    margin: 36px 0 8px;
    border: 0;
    padding: 0;
    max-width: 840px;
  }
  .article :global(blockquote p) {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-weight: 600;
    font-size: clamp(24px, 3.4vw, 34px);
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: #fff;
  }
</style>
