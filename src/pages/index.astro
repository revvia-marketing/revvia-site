---
import BaseLayout from '../layouts/BaseLayout.astro';
import CaseCard from '../components/CaseCard.astro';
import CTASection from '../components/CTASection.astro';
import GrowthAuditForm from '../components/GrowthAuditForm.astro';
import Faq from '../components/Faq.astro';
import Video from '../components/Video.astro';
import Comparison from '../components/Comparison.astro';
import BrandStrip from '../components/BrandStrip.astro';
import { resolveCover } from '../lib/images';
import {
  localBusinessSchema,
  faqPageSchema,
  type FaqItem,
} from '../lib/schema';

const services = [
  { n: '01', t: 'Paid Media', d: 'Meta and Google, run to revenue instead of clicks - built on tracking you can actually trust.' },
  { n: '02', t: 'Creative & Production', d: 'Photo, video, and UGC shot in-house - not stock, not art-directed over Slack.' },
  { n: '03', t: 'Email & SMS Retention', d: 'Klaviyo flows and campaigns that turn one-time buyers into repeat revenue.' },
  { n: '04', t: 'Tracking & Measurement', d: 'Clean attribution and blended MER, so you always know what’s actually working.' },
  { n: '05', t: 'SEO & GEO', d: 'Get found in Google and in AI search, with content that ranks and gets cited.' },
  { n: '06', t: 'Website & CRO', d: 'Fast, on-brand Shopify experiences tuned to convert the traffic you’ve earned.' },
];

const why = [
  { t: 'Local & in person', d: 'We’re a San Diego studio, and we show up - to plan, to shoot, to fix things in the room. Your growth team is here, not a screen in another time zone.' },
  { t: 'In-house production, on location', d: 'We shoot your photo, video, and lifestyle content ourselves - on location, in person, not art-directed over Slack.' },
  { t: 'You work with the founder', d: 'You get the owner on your account, not a junior learning on your budget.' },
  { t: 'Built for your size', d: 'Right-sized for $300K-$8M brands - too big for a freelancer, too small to be a rounding error at a national agency. Senior attention either way.' },
];

const reviews = [
  { p: 'By far the best marketing company I’ve worked with. They took the time to understand our business and built a plan completely tailored to us - creative and highly effective. I couldn’t be happier with the results.', who: 'Kristin', sub: 'For Every Need' },
  { p: 'One of the best marketing agencies I have dealt with. Very personable, they work quickly and well to increase revenue. There’s no company doing it like this at this cost.', who: 'Matt P.', sub: 'Personable & Helpful' },
  { p: 'Revvia has been instrumental in helping our firm raise brand awareness. They go above and beyond in terms of service and results as our outsourced CMO.', who: 'Don J.', sub: 'Raising Brand Awareness' },
];

const faqs: FaqItem[] = [
  { question: 'What does Revvia do?', answer: 'We’re a San Diego, full-stack, production-led growth studio for consumer & lifestyle brands. We run paid media, shoot creative in-house, build email and SMS retention, and keep your tracking clean - all under one roof, in person.' },
  { question: 'Who do you work with?', answer: 'Consumer & lifestyle brands - apparel, beauty, wellness, accessories, home, and food & beverage, plus multi-location and membership brands. Typically $300K to $8M in revenue, here in Southern California. Many are on Shopify; not all are online-only.' },
  { question: 'How does your pricing work?', answer: 'A monthly base plus a small percentage of ad spend, plus a growth bonus we only earn when we beat your efficiency baseline. Month-to-month, with pricing that stays the same. We win when you win.' },
  { question: 'Am I locked into a long contract?', answer: 'No. Every engagement is month-to-month. We earn the relationship each month - no multi-year lock-ins and no hidden fees.' },
  { question: 'Do you really produce everything in-house?', answer: 'Yes. Photo, video, and creative are produced by our own team - on location and in person, not outsourced or art-directed over Slack.' },
  { question: 'How do we get started?', answer: 'Start with a growth audit. We’ll show you exactly where your brand is leaking revenue, with no commitment - then you decide what’s next.' },
];

const schemas = [localBusinessSchema(), faqPageSchema(faqs)];
---
<BaseLayout
  title="Revvia - San Diego Growth Studio for Consumer & Lifestyle Brands"
  description="The San Diego growth studio that actually shows up - full-stack and in person, run by the founder, for consumer & lifestyle brands too big for a freelancer and too small for the national agencies."
  path="/"
  schemas={schemas}
>
  <header class="hero">
    <div class="hero-in">
      <div>
        <div class="eyebrow">San Diego · Consumer &amp; Lifestyle Brands</div>
        <h1>We run your whole growth engine - <span class="grad-text">in person, right here in San Diego.</span></h1>
        <p class="sub">Paid media, in-house production, retention, and clean tracking - one local studio for consumer and lifestyle brands. A senior team you can sit across the table from, built for your size. Revenue over impressions, month-to-month.</p>
        <div class="hero-cta">
          <a href="/contact" class="btn btn-lg">Get a Growth Audit</a>
          <a href="#reel" class="play"><span class="ring" aria-hidden="true">▶</span> Watch the reel</a>
        </div>
        <div class="sig grad-text">Marketing how it should be.</div>
      </div>
      <div class="hero-reel" id="reel">
        <Video provider="vimeo" id="1202242149" title="Revvia Showcase" ratio="16 / 9" />
      </div>
    </div>
  </header>

  <BrandStrip />

  <div class="trust-strip">
    <div class="wrap trust-in">
      <span>Revenue, not vanity metrics.</span>
      <span>Month-to-month, no lock-ins.</span>
      <span>We win when you win.</span>
    </div>
  </div>

  <section class="wedge">
    <div class="wrap">
      <div class="eyebrow">The problem</div>
      <h2 style="margin-top:14px">Your ad agency runs your ads. <span class="grad-text">Who's running everything else?</span></h2>
      <p>Your email flows, your tracking, your creative, your site. The growth you're missing usually isn't in spending more - it's in the leaks no one's fixing.</p>
    </div>
  </section>

  <section id="services">
    <div class="wrap">
      <div class="sec-head">
        <div class="eyebrow">What we do</div>
        <h2>One studio for the whole growth engine.</h2>
        <p>Most brands stitch together a media buyer, a freelance designer, and an email tool no one touches. We do all of it - and we make it work together.</p>
      </div>
      <div class="grid3">
        {services.map((s) => (
          <div class="pcard">
            <span class="pn grad-text">{s.n}</span>
            <h3>{s.t}</h3>
            <p>{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="work" class="work">
    <div class="wrap">
      <div class="sec-head">
        <div class="eyebrow">The work</div>
        <h2>Proof, not promises.</h2>
        <p>We lead with what we've made and what it earned. Here's the most recent.</p>
      </div>
      <div class="work-grid">
        <CaseCard
          href="/work/eversun"
          cover={resolveCover('eversun')}
          mediaStyle="background:linear-gradient(145deg,#2a1a0e,#3a2412 68%,#140d07)"
          tag="Beauty & Wellness · 28 Locations"
          name="EverSun/iTAN"
          stat="28 locations"
          label="One integrated growth system for a beloved 28-location SoCal brand."
        />
        <CaseCard
          href="/work/peter-grimm"
          cover={resolveCover('peter-grimm')}
          media="pg"
          name="Peter Grimm"
          stat="3.6×"
          label="Monthly revenue growth in six months - rebuilt mid-migration."
        />
        <CaseCard
          href="/work/voyage-air"
          cover={resolveCover('voyage-air')}
          media="va"
          name="Voyage Air Guitar"
          stat="&gt; full year"
          label="More net revenue in six months of 2026 than in all of 2025."
        />
      </div>
    </div>
  </section>

  <section id="reviews">
    <div class="wrap">
      <div class="sec-head">
        <div class="eyebrow">What clients say</div>
        <h2>Dozens of happy clients.</h2>
        <p>Our clients are our mission. Here's a little of what it's like to work with us.</p>
      </div>
      <div class="rgrid">
        {reviews.map((r) => (
          <div class="rcard">
            <div class="stars" aria-label="5 out of 5 stars">★★★★★</div>
            <p>&ldquo;{r.p}&rdquo;</p>
            <div class="who"><b>{r.who}</b> - {r.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="why" class="work">
    <div class="wrap">
      <div class="sec-head">
        <div class="eyebrow">Why Revvia</div>
        <h2>We're in your warehouse with a camera.</h2>
        <p>What you get from a local studio that runs your whole growth engine.</p>
      </div>
      <div class="grid2">
        {why.map((w) => (
          <div class="pcard">
            <h3>{w.t}</h3>
            <p>{w.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Comparison />

  <section id="faq">
    <div class="wrap">
      <div class="sec-head">
        <div class="eyebrow">FAQ</div>
        <h2>Questions, answered.</h2>
      </div>
      <Faq items={faqs} openFirst />
    </div>
  </section>

  <CTASection
    id="contact"
    heading={`Find your brand's <span class="grad-text">missing revenue.</span>`}
    lead="Tell us a little about your brand and we'll come back with a growth audit - exactly where the leaks are, no commitment."
  >
    <GrowthAuditForm id="home-growth-audit" />
  </CTASection>
</BaseLayout>

<style>
  /* Homepage-specific hero + reel (the inner pages use .page-hero instead). */
  .hero { position: relative; overflow: hidden; border-bottom: 1px solid var(--line); }
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(760px 460px at 80% -6%, rgba(254, 156, 28, 0.16), transparent 58%),
      radial-gradient(820px 520px at 92% 30%, rgba(236, 79, 101, 0.16), transparent 55%),
      radial-gradient(900px 600px at 6% 104%, rgba(138, 15, 173, 0.22), transparent 56%);
  }
  .hero-in {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 80px 28px 88px;
    position: relative;
    display: grid;
    grid-template-columns: 1.12fr 0.88fr;
    gap: 54px;
    align-items: center;
  }
  .hero h1 {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-weight: 800;
    font-size: clamp(40px, 5.6vw, 68px);
    letter-spacing: -0.02em;
    line-height: 1.03;
    margin: 18px 0 20px;
  }
  .hero p.sub { font-size: clamp(17px, 1.9vw, 20px); color: var(--muted); max-width: 540px; margin-bottom: 30px; }
  .play { display: inline-flex; align-items: center; gap: 11px; color: #fff; font-weight: 500; font-size: 15px; }
  .play .ring { width: 36px; height: 36px; border-radius: 50%; background: var(--grad); display: flex; align-items: center; justify-content: center; font-size: 11px; color: #fff; }
  .sig { margin-top: 32px; font-family: 'Bricolage Grotesque', sans-serif; font-style: italic; font-size: 15px; }
  .hero-reel { width: 100%; scroll-margin-top: 90px; }
  /* gradient-glow frame echoing the brand, behind the player */
  .hero-reel :global(.video-embed) { box-shadow: 0 24px 70px rgba(138, 15, 173, 0.28); }
  .wedge h2 { margin-top: 14px; }

  /* trust strip - the demoted parity claims as a slim qualifier bar */
  .trust-strip { border-bottom: 1px solid var(--line); background: var(--bg-2); }
  .trust-in {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 36px;
    justify-content: center;
    padding: 16px 28px;
    font-size: 14px;
    color: var(--muted);
  }
  .trust-in span { display: inline-flex; align-items: center; gap: 10px; }
  .trust-in span::before {
    content: "";
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--grad);
    flex-shrink: 0;
  }

  /* proof now holds 3 cards (EverSun lead + two case studies) */
  #work .work-grid { grid-template-columns: repeat(3, 1fr); }
  @media (max-width: 900px) { #work .work-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 620px) { #work .work-grid { grid-template-columns: 1fr; } }

  @media (max-width: 880px) {
    .hero-in { grid-template-columns: 1fr; gap: 36px; }
    .hero-reel { order: -1; }
  }
</style>
